   "source": [
    "import pandas as pd\n",
    "\n",
    "url = \"https://www.ecb.europa.eu/stats/eurofxref/eurofxref-daily.xml\"\n",
    "\n",
    "df = pd.read_xml(\n",
    "    url,\n",
    "    xpath=\".//e:Cube[@currency]\",\n",
    "    namespaces={\"e\": \"http://www.ecb.int/vocabulary/2002-08-01/eurofxref\"}\n",
    ")\n",
    "\n",
    "df.to_csv(\"actuell_currency.csv\", index=False)\n",
    "\n",
    "df\n"
   ]
  },
